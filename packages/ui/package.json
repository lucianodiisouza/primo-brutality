{
  "name": "@primo-brutality/ui",
  "version": "0.2.0",
  "description": "Neo-brutalist React Native component library",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucianodiisouza/primo-brutality.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/lucianodiisouza/primo-brutality/issues"
  },
  "homepage": "https://github.com/lucianodiisouza/primo-brutality#readme",
  "keywords": [
    "react-native",
    "expo",
    "nativewind",
    "components",
    "ui",
    "neo-brutalism",
    "design-system"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": [
    "./global.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./global.css": "./global.css"
  },
  "files": [
    "dist",
    "global.css"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "nativewind": ">=4.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.74.0"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.4.4",
    "@storybook/react-native-web-vite": "^10.4.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^26.1.0",
    "nativewind": "^4.1.23",
    "react": "^19.1.0",
    "react-dom": "^19.2.7",
    "react-native": "^0.79.5",
    "react-native-web": "^0.20.0",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.6"
  }
}
