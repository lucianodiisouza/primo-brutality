{
  "name": "primo-brutality",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "storybook": "pnpm --filter @primo-brutality/storybook dev",
    "build-storybook": "pnpm --filter @primo-brutality/storybook build",
    "build": "pnpm --filter @primo-brutality/ui build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "test": "pnpm --filter @primo-brutality/ui test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.61.1"
  }
}
